# Copy this file to `.env` and fill in real credentials. DO NOT commit real secrets.

# Backend
DB_HOST=127.0.0.1
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT secret for signing tokens
JWT_SECRET=replace_with_a_strong_random_value

# Email Service (Hostinger SMTP)
EMAIL_FROM=noreply@creative4ai.com
EMAIL_FROM_NAME="Creative4AI Verification"
SMTP_HOST=smtp.hostinger.com
SMTP_USER=jessica@creative4ai.com
MAILBOX_PASSWORD=REPLACE_WITH_REAL_PASSWORD
SMTP_SECURE=ssl
SMTP_PORT=465

# Frontend
VITE_API_BASE_URL=http://localhost:5173/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
